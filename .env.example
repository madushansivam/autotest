# =============================================================================
# Codebase A — working system (server.js, run-pipeline.js, public/)
# =============================================================================

# Required: your HuggingFace API key (free — get one at huggingface.co/settings/tokens)
# Used by: run-pipeline.js, generate-tests.js, generate-playwright-scripts.js, test-hf-api.js
HUGGINGFACE_API_KEY=hf_your_api_key_here

# =============================================================================
# Codebase B — architectural exploration (backend/, frontend/, eval/, supabase/)
# These variables are only needed if running the TypeScript/React/Supabase rebuild.
# See the README for important caveats about Codebase B's status.
# =============================================================================

# Supabase project (Settings > API in the Supabase dashboard)
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-key-here
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# Backend server
PORT=3001
NODE_ENV=development

# SSRF guard — additional hostnames to block (comma-separated)
INTERNAL_DOMAIN_BLOCKLIST=localhost,internal.example.com

# Pipeline budget caps
MAX_PAGES_PER_RUN=8
MAX_LLM_CALLS_PER_RUN=20

# Rate limiting
RATE_LIMIT_MAX_RUNS=5
RATE_LIMIT_WINDOW_MS=3600000

# Frontend (Vite exposes VITE_* vars to the browser)
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_BASE_URL=http://localhost:3001
