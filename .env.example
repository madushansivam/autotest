# ─── Supabase ───────────────────────────────────────────────────────────────
# Your project URL, found at Settings > API in the Supabase dashboard
SUPABASE_URL=https://your-project-ref.supabase.co

# Public anon key – safe to expose to the browser
SUPABASE_ANON_KEY=your-anon-key-here

# Service role key – NEVER expose to the browser, backend-only
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key-here

# ─── HuggingFace ─────────────────────────────────────────────────────────────
# Free API key from https://huggingface.co/settings/tokens
# Required for Llama-3.1-8B-Instruct inference
HUGGINGFACE_API_KEY=hf_your_api_key_here

# ─── Backend server ──────────────────────────────────────────────────────────
PORT=3001
NODE_ENV=development

# Comma-separated hostnames that should be treated as internal and blocked
# by the SSRF guard in addition to private IP ranges
INTERNAL_DOMAIN_BLOCKLIST=localhost,internal.example.com

# ─── Pipeline budgets ────────────────────────────────────────────────────────
# Hard cap: pages crawled per run
MAX_PAGES_PER_RUN=8

# Hard cap: LLM API calls per run (test-case gen + script gen combined)
MAX_LLM_CALLS_PER_RUN=20

# ─── Rate limiting (per authenticated user) ───────────────────────────────────
# Maximum pipeline runs per window
RATE_LIMIT_MAX_RUNS=5
# Window size in milliseconds (default: 1 hour)
RATE_LIMIT_WINDOW_MS=3600000

# ─── Frontend (Vite exposes VITE_* vars to the browser) ──────────────────────
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key-here
VITE_API_BASE_URL=http://localhost:3001
